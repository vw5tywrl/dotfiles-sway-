{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,

    "modules-left": ["sway/workspaces", "network", "battery"],
    "modules-center":  ["clock", "sway/language","keyboard-state"],
    "modules-right": [
	"pulseaudio",
        "cpu",
	"memory", 
        "temperature", 
	"tray",
    ],

    // Configurazione dei singoli moduli
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },

    "keyboard-state": {
	"capslock": true,
	"format": "{icon}",
	"format-icons": {
            "locked": "[CAPS]",
            "unlocked": ""
	}
    },


    "network": {
	"interval": 5,
        "format-wifi": "[{essid}]",
        "format-ethernet": "ETH: Connesso",
        "format-disconnected": "WIFI: Off",
        "tooltip-format": "{ifname} via {gwaddr}",
        "max-length": 20,
	"on-click": "nm-connection-editor"
    },

    "cpu": {
        "interval": 2,
        "format": "[CPU {usage}%]",
        "tooltip": false
    },

    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon0/temp1_input",
        "critical-threshold": 80,
        "format": "[TEMP {temperatureC}°C]",
        "tooltip": false
    },

    "memory": {
        "interval": 5,
        "format": "[RAM {percentage}%]",
        "tooltip-format": "Totale: {total:0.1f}GiB\nUsata: {used:0.1f}GiB"
    },

    "battery": {
        "interval": 2,
        "states": { "warning": 30, "critical": 15 },
        "format": "[BAT {capacity}% ({power:0.1f}W)]",
        "format-charging": "[AC {capacity}% (+{power:0.1f}W)]",
        "format-plugged": "[AC {capacity}% (+{power:0.1f}W)]",
        "tooltip": true   
     },

     "sway/language": {
	"format": "[{}]",
 	"format-en": "US",
	"format-it": "IT"
     },

    "clock": {
        "interval": 60,
        "format": "[{:%a %d, %H:%M}]",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },	

    "pulseaudio": {
	"format": "[{volume}%]",
	"format-muted": "[MUTED]",
	"on-click": "pavucontrol"
    }   
}
