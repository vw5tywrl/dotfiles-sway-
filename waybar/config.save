{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,

    "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": [
        "cpu", 
        "temperature", 
        "memory", 
        "battery", 
	"pulseaudio", 
	"tray",
	"sway/language"
    ],

    // Configurazione dei singoli moduli
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },

    "sway/window": {
        "max-length": 40,
        "separate-outputs": true
    },

    "cpu": {
        "interval": 2,
        "format": "CPU {usage}%",
        "tooltip": false
    },

    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon0/temp1_input",
        "critical-threshold": 80,
        "format": "TEMP {temperatureC}°C",
        "tooltip": false
    },

    "memory": {
        "interval": 5,
        "format": "RAM {usage}%",
        "tooltip-format": "Totale: {total:0.1f}GiB\nUsata: {used:0.1f}GiB"
    },

    "battery": {
        "interval": 2,
        "states": { "warning": 30, "critical": 15 },
        "format": "BAT {capacity}% ({power:0.1f}W)",
        "format-charging": "CHG {capacity}% (+{power:0.1f}W)",
        "format-plugged": "AC {capacity}% (+{power:0.1f}W)",
        "tooltip": true   
     },

     "sway/language": {
	"format": "{}",
 	"format-en": "US",
	"format-it": "IT"
     },

    "clock": {
        "interval": 60,
        "format": "[{:%a %d, %H:%M}]",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },	

    "pulseaudio": {
	"format": "VOL{"
    }   
}
